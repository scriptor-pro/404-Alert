{
  "name": "baudouin/404-alert",
  "description": "Un plugin WordPress qui envoie une notification email à chaque erreur 404 détectée",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Baudouin",
      "email": "bvh@scriptor.pro"
    }
  ],
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "php-stubs/wordpress-stubs": "^6.0",
    "phpstan/phpstan": "^2.0",
    "yoast/phpunit-polyfills": "^2.0",
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^3.0",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs --standard=phpcs.xml includes/ 404-alert.php",
    "lint-fix": "phpcbf --standard=phpcs.xml includes/ 404-alert.php",
    "stan": "phpstan analyse -c phpstan.neon"
  },
  "keywords": [
    "wordpress",
    "plugin",
    "404",
    "error-detection",
    "email-notification"
  ],
  "minimum-stability": "stable",
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
